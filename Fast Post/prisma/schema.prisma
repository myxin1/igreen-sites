generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  ADMIN
  EDITOR
  VIEWER
}

enum SocialProvider {
  INSTAGRAM
  FACEBOOK
  TIKTOK
}

enum AccountStatus {
  ACTIVE
  EXPIRED
  ERROR
  DISCONNECTED
}

enum MediaType {
  VIDEO
  IMAGE
}

enum MediaStatus {
  UPLOADED
  PROCESSING
  READY
  FAILED
}

enum PostStatus {
  SCHEDULED
  QUEUED
  PROCESSING
  PUBLISHED
  FAILED
  CANCELLED
}

enum LogLevel {
  INFO
  WARN
  ERROR
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String?
  role         UserRole  @default(OWNER)
  profiles     Profile[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Profile {
  id             String          @id @default(cuid())
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  avatarUrl      String?
  description    String?
  active         Boolean         @default(true)
  socialAccounts SocialAccount[]
  media          Media[]
  folders        MediaFolder[]
  scheduleSlots  ScheduleSlot[]
  posts          Post[]
  logs           Log[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model SocialAccount {
  id                    String         @id @default(cuid())
  profileId             String
  profile               Profile        @relation(fields: [profileId], references: [id], onDelete: Cascade)
  provider              SocialProvider
  externalAccountId     String?
  username              String
  status                AccountStatus  @default(DISCONNECTED)
  accessTokenEncrypted  String?
  refreshTokenEncrypted String?
  expiresAt             DateTime?
  destinations          PostDestination[]
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  @@unique([profileId, provider])
}

model MediaFolder {
  id        String   @id @default(cuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name      String
  media     Media[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Media {
  id           String      @id @default(cuid())
  profileId    String
  profile      Profile     @relation(fields: [profileId], references: [id], onDelete: Cascade)
  folderId     String?
  folder       MediaFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  filename     String
  originalName String
  mimeType     String
  type         MediaType
  size         Int
  storageKey   String
  publicUrl    String?
  status       MediaStatus @default(UPLOADED)
  posts        PostMedia[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model ScheduleSlot {
  id        String   @id @default(cuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  hour      Int
  minute    Int
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([profileId, hour, minute])
}

model Post {
  id            String             @id @default(cuid())
  profileId     String
  profile       Profile            @relation(fields: [profileId], references: [id], onDelete: Cascade)
  caption       String?
  scheduledAt   DateTime
  status        PostStatus         @default(SCHEDULED)
  zernioPostId  String?
  publishedUrl  String?
  media         PostMedia[]
  destinations  PostDestination[]
  queue         PublicationQueue?
  logs          Log[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([profileId, scheduledAt])
  @@index([status, scheduledAt])
}

model PostMedia {
  id      String @id @default(cuid())
  postId  String
  post    Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  mediaId String
  media   Media  @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  order   Int    @default(0)
}

model PostDestination {
  id              String         @id @default(cuid())
  postId          String
  post            Post           @relation(fields: [postId], references: [id], onDelete: Cascade)
  provider        SocialProvider
  socialAccountId String?
  socialAccount   SocialAccount? @relation(fields: [socialAccountId], references: [id], onDelete: SetNull)
  status          PostStatus      @default(SCHEDULED)
  externalPostId  String?
  publishedUrl    String?
  errorMessage    String?
}

model PublicationQueue {
  id           String     @id @default(cuid())
  postId       String     @unique
  post         Post       @relation(fields: [postId], references: [id], onDelete: Cascade)
  jobId        String?
  status       PostStatus @default(SCHEDULED)
  attempts     Int        @default(0)
  scheduledFor DateTime
  processedAt  DateTime?
  createdAt    DateTime   @default(now())
}

model WebhookEvent {
  id         String   @id @default(cuid())
  provider   String
  eventType  String
  externalId String?
  payload    Json
  processed  Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model Log {
  id        String   @id @default(cuid())
  profileId String?
  profile   Profile? @relation(fields: [profileId], references: [id], onDelete: SetNull)
  postId    String?
  post      Post?    @relation(fields: [postId], references: [id], onDelete: SetNull)
  level     LogLevel @default(INFO)
  type      String
  message   String
  metadata  Json?
  createdAt DateTime @default(now())
}
