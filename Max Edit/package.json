{
  "name": "max-edit-backend",
  "version": "1.0.0",
  "description": "Max Edit backend - batch video editor SaaS",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:init": "node scripts/init-db.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init"
  },
  "engines": {
    "node": ">=20.19"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "archiver": "^8.0.0",
    "body-parser": "^1.20.2",
    "bullmq": "^5.77.6",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "fluent-ffmpeg": "^2.1.2",
    "helmet": "^7.0.0",
    "ioredis": "^5.3.2",
    "multer": "^1.4.5-lts.1",
    "uuid": "^11.1.1",
    "zod": "^3.22.2"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/body-parser": "^1.19.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.17",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/helmet": "^4.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^18.16.19",
    "@types/uuid": "^10.0.0",
    "prisma": "^5.22.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.1.6"
  }
}
