.ctag{display:inline-block;background:rgba(139,26,26,.09);color:var(--rot);
  font-size:.64rem;letter-spacing:.1em;text-transform:uppercase;font-weight:700;
  padding:.2rem .65rem;border-radius:2px;margin-bottom:.5rem;font-family:'DM Sans',sans-serif}
.card-body h3{
  font-family:'Playfair Display',serif;font-size:1rem;font-weight:700;
  color:var(--dark);line-height:1.3;margin-bottom:.45rem}
@media(min-width:480px){.card-body h3{font-size:1.05rem}}
.card-body p{font-family:'Lora',serif;font-size:.86rem;color:var(--muted);line-height:1.65}
.card-body a.card-link{
  display:inline-flex;align-items:center;margin-top:auto;padding-top:.9rem;
  color:var(--gold);font-weight:600;font-size:.83rem;
  font-family:'DM Sans',sans-serif;min-height:44px;
}
.card-body a.card-link:hover{color:var(--rot)}

/* ═══════════════════════════════════════════
   COMPARTILHAMENTO SOCIAL
═══════════════════════════════════════════ */
.bf-share-wrap{background:#fff;padding:0 0 3rem}
.bf-share{
  margin:0;padding:1.3rem 1.2rem;
  background:var(--cream);border-radius:var(--radius);
  border-top:3px solid var(--gold);
}
@media(min-width:480px){.bf-share{padding:1.4rem 1.6rem}}
.bf-share-title{
  font-family:'Playfair Display',serif;font-size:.9rem;font-weight:700;
  color:var(--dark);letter-spacing:.04em;margin-bottom:.9rem;
  display:flex;align-items:center;gap:.5rem;
}
.bf-share-btns{display:flex;flex-direction:column;gap:.6rem}
@media(min-width:480px){.bf-share-btns{flex-direction:row;flex-wrap:wrap;gap:.75rem}}
.bf-share-btn{
  display:flex;align-items:center;justify-content:center;gap:.4rem;
  padding:.65rem 1rem;border-radius:4px;font-size:.78rem;font-weight:700;
  cursor:pointer;border:none;text-decoration:none;
  transition:opacity .2s,transform .15s;min-height:44px;
