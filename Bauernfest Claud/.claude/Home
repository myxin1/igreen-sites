}
.bf-share-btn:hover{opacity:.88;transform:translateY(-2px)}
@media(min-width:480px){.bf-share-btn{flex:0 0 auto;justify-content:flex-start}}
.bf-share-btn.fb{background:#1877F2;color:#fff}
