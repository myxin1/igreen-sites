.bf-toast{
  display:none;position:fixed;bottom:1.2rem;right:1rem;left:1rem;
  background:var(--dark);color:var(--glt);padding:.7rem 1.2rem;
  border-radius:6px;font-size:.84rem;font-weight:600;text-align:center;
  box-shadow:0 8px 24px rgba(0,0,0,.25);z-index:9999;
