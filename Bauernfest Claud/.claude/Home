<script>
(function(){
  /* ── Hamburger menu ── */
  var burger=document.getElementById('bfBurger'),menu=document.getElementById('bfMenu');
  if(burger&&menu){
    burger.addEventListener('click',function(){
      var open=menu.classList.toggle('bfopen');
      burger.classList.toggle('open',open);
      burger.setAttribute('aria-expanded',String(open));
    });
    menu.querySelectorAll('a').forEach(function(a){
      a.addEventListener('click',function(){
        menu.classList.remove('bfopen');
        burger.classList.remove('open');
        burger.setAttribute('aria-expanded','false');
      });
    });
    /* fecha menu ao clicar fora */
    document.addEventListener('click',function(e){
      if(!burger.contains(e.target)&&!menu.contains(e.target)){
        menu.classList.remove('bfopen');
        burger.classList.remove('open');
        burger.setAttribute('aria-expanded','false');
      }
    });
  }
})();

/* ── Ticker: duplica para loop contínuo ── */
(function(){
  var tk=document.getElementById('bfTicker');
  if(tk){tk.innerHTML+=tk.innerHTML;}
})();

/* ── Ticker: pausar (mobile) ── */
var bfTickerPaused=false;
function bfTickerToggle(){
  var tk=document.getElementById('bfTicker'),icon=document.getElementById('bfTickerPauseIcon');
  if(!tk)return;
  bfTickerPaused=!bfTickerPaused;
  tk.classList.toggle('paused',bfTickerPaused);
  if(icon)icon.textContent=bfTickerPaused?'▶':'⏸';
}

/* ── Newsletter ── */
function bfNlSubmit(btn){
  var inp=btn.parentElement.querySelector('input');
  if(!inp||!inp.value||!inp.value.includes('@')){
    inp.style.borderColor='#c0392b';setTimeout(function(){inp.style.borderColor='';},1500);return;
  }
  btn.textContent='✅ Inscrito!';btn.disabled=true;inp.disabled=true;inp.style.opacity='.5';
}

/* ── Copiar link ── */
function bfCopyLink(url){
  var u=url||window.location.href;
  if(navigator.clipboard&&window.isSecureContext){
    navigator.clipboard.writeText(u).then(bfShowToast);
  } else {
    var t=document.createElement('textarea');
    t.value=u;t.style.cssText='position:fixed;opacity:0;top:0;left:0';
    document.body.appendChild(t);t.focus();t.select();
    try{document.execCommand('copy');}catch(e){}
    document.body.removeChild(t);bfShowToast();
  }
}
/* ── FAQ Accordion ── */
(function(){
  document.querySelectorAll('.bf-faq-q').forEach(function(btn){
    btn.addEventListener('click',function(){
      var item=btn.closest('.bf-faq-item');
      var open=item.classList.toggle('open');
      btn.setAttribute('aria-expanded',String(open));
    });
  });
})();

function bfShowToast(){
  var t=document.getElementById('bfToast');
  if(!t)return;
  t.classList.add('show');
  setTimeout(function(){t.classList.remove('show');},2500);
}
</script>
