@media(min-width:480px){
  .bf-hero-btns .btnp,.bf-hero-btns .btno{width:auto}
}

/* stats bar */
.bf-stats{
  position:relative;z-index:5;
  display:grid;grid-template-columns:1fr 1fr;
  border-top:1px solid rgba(200,146,42,.14);
}
@media(min-width:640px){.bf-stats{grid-template-columns:repeat(4,1fr)}}

.bf-stat{
  text-align:center;padding:1.4rem 1rem;
  border-right:1px solid rgba(200,146,42,.1);
  border-bottom:1px solid rgba(200,146,42,.1);
}
.bf-stat:nth-child(2n){border-right:none}
@media(min-width:640px){
  .bf-stat{border-bottom:none}
  .bf-stat:nth-child(2n){border-right:1px solid rgba(200,146,42,.1)}
  .bf-stat:last-child{border-right:none}
}
.bf-stat-num{
  font-family:'Playfair Display',serif;
  font-size:clamp(1.6rem,4vw,2rem);font-weight:900;color:var(--glt)
}
.bf-stat-lbl{
  font-size:.65rem;letter-spacing:.1em;text-transform:uppercase;
  color:rgba(255,255,255,.4);margin-top:.3rem;font-family:'DM Sans',sans-serif;
}

/* ═══════════════════════════════════════════
   INTRO SEO BLOCK
═══════════════════════════════════════════ */
.bf-intro{background:#fff;padding:2.5rem 0 0}
@media(min-width:768px){.bf-intro{padding:3.5rem 0 0}}
.bf-intro h2{
  font-family:'Playfair Display',serif;
  font-size:clamp(1.35rem,3.5vw,2.1rem);
  font-weight:900;color:var(--dark);line-height:1.25;margin-bottom:1.4rem;
}
.bf-intro p{
  font-family:'Lora',serif;font-size:clamp(.93rem,2.2vw,1rem);
  color:var(--text);line-height:1.88;margin-bottom:1rem;
  overflow-wrap:break-word;word-break:break-word;
}
.bf-intro strong{color:var(--dark)}

/* ═══════════════════════════════════════════
   CARDS GRID (SILOS)
═══════════════════════════════════════════ */
.bf-silos{background:#fff;padding:2.5rem 0 3rem}
@media(min-width:768px){.bf-silos{padding:3rem 0 4rem}}

.cards-grid{
  display:grid;
  grid-template-columns:1fr;
  gap:1.2rem;margin-top:1.8rem;
}
@media(min-width:480px){.cards-grid{grid-template-columns:repeat(2,1fr)}}
@media(min-width:1024px){.cards-grid{grid-template-columns:repeat(3,1fr);gap:1.4rem}}

.card{
  background:#fff;border-radius:var(--radius);overflow:hidden;
  box-shadow:0 4px 18px rgba(0,0,0,.07);
  transition:transform .25s,box-shadow .25s;
  display:flex;flex-direction:column;
  border:1px solid rgba(0,0,0,.05);
}
.card:hover{transform:translateY(-4px);box-shadow:0 14px 36px rgba(0,0,0,.12)}
.card:active{transform:translateY(-2px)}

/* imagem do card — aspect ratio em vez de altura fixa */
.card-img-wrap{position:relative;width:100%;padding-top:55%;overflow:hidden}
.card-img-wrap img{
  position:absolute;inset:0;width:100%;height:100%;
  object-fit:cover;transition:transform .4s;
}
.card:hover .card-img-wrap img{transform:scale(1.04)}

.card-body{padding:1.1rem 1.2rem;flex:1;display:flex;flex-direction:column}
