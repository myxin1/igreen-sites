  font-size:clamp(.95rem,2.5vw,1.06rem);line-height:1.8;
}
.bf-hero-sub strong{color:rgba(255,255,255,.92)}

.bf-hero-btns{
  display:flex;flex-direction:column;gap:.75rem;
  width:100%;max-width:360px;margin-top:2rem;
}
@media(min-width:480px){
  .bf-hero-btns{flex-direction:row;flex-wrap:wrap;justify-content:center;
