<style>
/* ═══════════════════════════════════════════
   RESET & VARIÁVEIS
═══════════════════════════════════════════ */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{-webkit-text-size-adjust:100%;scroll-behavior:smooth}
body{overflow-x:hidden;-webkit-tap-highlight-color:transparent}
img{max-width:100%;height:auto;display:block}
a{text-decoration:none}
ul{list-style:none}

:root{
  --rot:#8B1A1A;
  --gold:#C8922A;
  --glt:#E8B84B;
  --dark:#1A1008;
  --cream:#F9F3E8;
  --text:#2C1A0E;
  --muted:#7A6048;
  --radius:8px;
  --nav-h:60px;
}

/* ═══════════════════════════════════════════
   UTILITÁRIOS
═══════════════════════════════════════════ */
.bfc{max-width:1160px;margin:0 auto;padding:0 1rem;width:100%}
@media(min-width:640px){.bfc{padding:0 1.5rem}}
@media(min-width:1024px){.bfc{padding:0 2rem}}

.lbl{display:block;font-size:.7rem;letter-spacing:.2em;text-transform:uppercase;
  color:var(--gold);font-weight:700;margin-bottom:.6rem;font-family:'DM Sans',sans-serif}
.ttl{font-family:'Playfair Display',serif;font-size:clamp(1.5rem,5vw,2.6rem);
  font-weight:900;line-height:1.15;color:var(--dark)}
.ttl em{font-style:italic;color:var(--rot)}

/* botões — touch targets ≥ 44px */
.btnp{display:inline-flex;align-items:center;justify-content:center;
  background:var(--gold);color:var(--dark);padding:.85rem 1.8rem;
  border-radius:4px;font-weight:700;font-size:.92rem;min-height:44px;
  transition:background .2s,transform .15s;cursor:pointer;border:none;
  font-family:'DM Sans',sans-serif;white-space:nowrap}
.btnp:hover{background:var(--glt);transform:translateY(-2px);color:var(--dark)}
.btno{display:inline-flex;align-items:center;justify-content:center;
  border:1px solid rgba(255,255,255,.38);color:#fff;padding:.85rem 1.8rem;
  border-radius:4px;font-weight:500;font-size:.92rem;min-height:44px;
  transition:border-color .2s,color .2s,transform .15s;white-space:nowrap;
  font-family:'DM Sans',sans-serif}
.btno:hover{border-color:var(--glt);color:var(--glt);transform:translateY(-2px)}

/* ═══════════════════════════════════════════
   NAV
═══════════════════════════════════════════ */
.bfnav{
  position:relative;z-index:100;
  display:flex;align-items:center;justify-content:space-between;
  padding:0 1rem;height:var(--nav-h);
  border-bottom:1px solid rgba(200,146,42,.14);
  background:var(--dark);
}
@media(min-width:640px){.bfnav{padding:0 1.5rem}}
@media(min-width:1024px){.bfnav{padding:0 2.5rem}}

.bflogo{font-family:'Playfair Display',serif;font-size:1.5rem;font-weight:900;
  color:var(--glt);letter-spacing:.04em;flex-shrink:0}
.bflogo span{color:#fff}

/* menu desktop */
.bfnl{display:none;align-items:center;gap:1.5rem}
.bfnl a{color:rgba(255,255,255,.7);font-size:.8rem;font-weight:500;
  letter-spacing:.06em;text-transform:uppercase;transition:color .2s;
  min-height:44px;display:flex;align-items:center}
.bfnl a:hover{color:var(--glt)}
.bfnl .ncta{background:var(--gold);color:var(--dark)!important;
  padding:.44rem 1.1rem;border-radius:4px;font-weight:700!important}
.bfnl .ncta:hover{background:var(--glt)}

@media(min-width:860px){
  .bfnl{display:flex}
  .bfburg{display:none!important}
}

/* hamburger */
.bfburg{display:flex;flex-direction:column;gap:5px;cursor:pointer;
  background:none;border:none;padding:.6rem;min-width:44px;min-height:44px;
  align-items:center;justify-content:center}
.bfburg span{display:block;width:24px;height:2px;background:var(--glt);
  border-radius:2px;transition:all .3s}
.bfburg.open span:nth-child(1){transform:translateY(7px) rotate(45deg)}
.bfburg.open span:nth-child(2){opacity:0;transform:scaleX(0)}
.bfburg.open span:nth-child(3){transform:translateY(-7px) rotate(-45deg)}

/* menu mobile dropdown */
.bfnl.bfopen{
  display:flex;flex-direction:column;align-items:stretch;
  position:absolute;top:var(--nav-h);left:0;right:0;
  background:#130c02;border-top:1px solid rgba(200,146,42,.14);
  padding:.5rem 0 1rem;gap:0;z-index:99;
  box-shadow:0 8px 24px rgba(0,0,0,.4);
}
.bfnl.bfopen li{border-bottom:1px solid rgba(255,255,255,.05)}
.bfnl.bfopen a{
  display:block;padding:1rem 1.5rem;font-size:.9rem;
  min-height:52px;display:flex;align-items:center;
  color:rgba(255,255,255,.75)
}
.bfnl.bfopen a:hover{color:var(--glt);background:rgba(200,146,42,.06)}
.bfnl.bfopen .ncta{
  margin:1rem 1.5rem 0;padding:.75rem 1rem;
  display:flex;align-items:center;justify-content:center;
  border-radius:4px;font-size:.88rem;
}

/* ═══════════════════════════════════════════
   TICKER BAR
═══════════════════════════════════════════ */
.bftk-bar{
  background:#140b02;border-bottom:1px solid rgba(200,146,42,.2);
  overflow:hidden;display:flex;align-items:stretch;height:38px;
}
.bftk-label{
  background:var(--gold);padding:0 .9rem;
  display:none;align-items:center;flex-shrink:0;z-index:2;
}
@media(min-width:1025px){.bftk-label{display:flex}}
.bftk-label span{font-family:'DM Sans',sans-serif;font-size:.68rem;
  font-weight:800;color:var(--dark);letter-spacing:.1em;
  text-transform:uppercase;white-space:nowrap}

.bftk-track{flex:1;overflow:hidden;position:relative;display:flex;align-items:center}
#bfTicker{display:flex;align-items:center;white-space:nowrap;will-change:transform;
  animation:bftickerscroll 240s linear infinite}
#bfTicker:hover{animation-play-state:paused}
#bfTicker.paused{animation-play-state:paused}
@keyframes bftickerscroll{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}

.bftk-item{font-family:'DM Sans',sans-serif;font-size:.75rem;
  color:rgba(255,255,255,.6);padding:0 .4rem}
.bftk-link{color:rgba(255,255,255,.75);transition:color .2s}
.bftk-link:hover{color:var(--glt)}
.bftk-curiosity{color:rgba(200,146,42,.85)}
.bftk-sep{color:var(--gold);font-size:.55rem;opacity:.5;flex-shrink:0}
.bftk-gap{display:inline-block;width:140px;flex-shrink:0}

.bftk-pause{
  display:none;background:rgba(200,146,42,.12);
  border:none;border-left:1px solid rgba(200,146,42,.2);
  padding:0 .8rem;cursor:pointer;flex-shrink:0;
  align-items:center;justify-content:center;
  min-width:44px;font-size:.85rem;
}
@media(max-width:1024px){
  .bftk-pause{display:flex}
  #bfTicker{animation-duration:280s}
  #bfTicker:hover{animation-play-state:running}
  .bftk-gap{width:100px}
}
@media(max-width:480px){
  .bftk-item{font-size:.7rem}
  .bftk-gap{width:60px}
  #bfTicker{animation-duration:200s}
}

/* ═══════════════════════════════════════════
   HERO
═══════════════════════════════════════════ */
.bf-hero{
  background:var(--dark);position:relative;overflow:hidden;
}
.bf-hero::before{
  content:'';position:absolute;inset:0;
  background:
    radial-gradient(ellipse 80% 60% at 50% 30%,rgba(200,146,42,.16) 0%,transparent 70%),
    linear-gradient(175deg,#0e0603 0%,#1a0d05 45%,#2a1508 100%);
}
.bf-hero-body{
  position:relative;z-index:5;text-align:center;
  padding:3.5rem 1rem 3rem;
  display:flex;flex-direction:column;align-items:center;
}
@media(min-width:640px){.bf-hero-body{padding:4.5rem 1.5rem 3.5rem}}
@media(min-width:1024px){.bf-hero-body{padding:5.5rem 2rem 4.5rem}}

.pg-badge{
  display:inline-block;border:1px solid var(--gold);color:var(--glt);
  font-size:.68rem;letter-spacing:.14em;text-transform:uppercase;
  padding:.32rem .9rem;border-radius:2px;margin-bottom:1.2rem;
  font-family:'DM Sans',sans-serif;
}
.bf-hero h1{
  font-family:'Playfair Display',serif;
  font-size:clamp(2.1rem,8vw,5.4rem);
